# Storyblok CMS – Konfiguration
# Kopiere diese Datei zu ".env.local" und trage die Werte aus deinem
# Storyblok-Space ein. OHNE diese Variablen funktioniert die Seite weiterhin
# mit den lokalen Default-Inhalten (src/site/content/site.ts).

# --- Server-seitig (Build-Zeit, Content Delivery API) ---
# Preview-Token = ungespeicherte Entwuerfe sichtbar; Public-Token = nur
# veroeffentlichte Inhalte.
STORYBLOK_TOKEN=
# Region des Spaces: eu | us | ap | ca | cn
STORYBLOK_REGION=eu
# Welche Version geladen wird: published (Standard) oder draft (Vorschau).
STORYBLOK_VERSION=published

# --- Client-seitig (Visual Editor / Live-Vorschau) ---
# Oeffentlicher Bridge-Token (muss mit NEXT_PUBLIC_ beginnen).
NEXT_PUBLIC_STORYBLOK_TOKEN=
NEXT_PUBLIC_STORYBLOK_REGION=eu

# --- Passwortschutz (HTTP Basic Auth) ---
# Nur aktiv, wenn SITE_PASSWORD gesetzt ist. Auf Vercel unter
# Settings -> Environment Variables anlegen, um die Seite zu schuetzen.
# Lokal in ".env.local" setzen, wenn du die Abfrage testen willst.
# SITE_PASSWORD=geheim
# SITE_USER=wohlfahrt
